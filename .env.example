# Discord Bot Token
# Получите на https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Префикс команд (по умолчанию /)
BOT_PREFIX=/

# Настройки для хоста bothost.ru
# Хост может запустить только bot.py, поэтому все настройки через переменные окружения
HOST=bothost.ru
PORT=8080

# Настройки для голосового функционала
VOICE_ENABLED=true
FFMPEG_PATH=/usr/bin/ffmpeg

# Дополнительные настройки
DEBUG=false
LOG_LEVEL=INFO